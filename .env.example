# For Supabase pooler (recommended): use port 6543 with pgbouncer=true to disable
# prepared statements (required for PgBouncer transaction mode) and set connection limits.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20
DATABASE_URL=postgresql://user:password@localhost:5432/applyng
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
RESEND_API_KEY=re_your_resend_api_key
NEXT_PUBLIC_ADSENSE_ID=ca-pub-your-adsense-id
CRON_SECRET=your-cron-secret-generate-random-string
ADMIN_EMAIL=admin@applyng.com
NODE_ENV=development
